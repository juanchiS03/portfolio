---
import SocialMedia from "./SocialMedia.astro";
import Technologies from "./Technologies.astro";
---

<section
  class="flex flex-col items-center justify-center min-h-[80vh] px-4 py-32 text-center"
>
  <div
    class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-64 bg-purple-500/20 rounded-full blur-[120px] -z-10"
  >
  </div>

  <h1
    class="text-white text-6xl md:text-8xl font-serif font-bold tracking-tighter"
  >
    Hey! Soy <span
      class="text-transparent bg-clip-text bg-linear-to-r from-yellow-300 to-orange-400"
      >Juan</span
    >
  </h1>

  <p
    class="mt-6 text-white text-lg md:text-xl max-w-xl font-light leading-relaxed"
  >
    Ingeniero Informático y Consultor Salesforce. <br />
    Especializado en <span class="text-white">Java</span> y arquitecturas web modernas.
  </p>

  <SocialMedia />

  <section class="max-w-4xl mx-auto py-8 px-6 relative">
    <div
      class="absolute inset-0 bg-purple-500/10 rounded-full blur-[100px] pointer-events-none"
    >
    </div>

    <div
      class="relative bg-slate-900/60 border border-slate-700/50 p-10 rounded-3xl backdrop-blur-xl shadow-[0_0_30px_rgba(168,85,247,0.1)]"
    >
      <p class="text-slate-300 text-lg md:text-xl font-light leading-relaxed">
        Como <strong class="text-white">Ingeniero y Consultor Salesforce</strong
        >, me apasiona resolver problemas complejos uniendo la robustez del
        backend en <span
          class="text-transparent bg-clip-text bg-linear-to-r from-orange-400 to-yellow-300 font-medium"
          >Java</span
        > con la agilidad del frontend moderno en <span
          class="text-transparent bg-clip-text bg-linear-to-r from-purple-400 to-pink-300 font-medium"
          >Astro</span
        >.
      </p>
    </div>
  </section>

  <Technologies />

  <div class="mt-6">
    <a
      href="#projects"
      class="px-8 py-3 bg-[#ffad11] text-slate-950 font-bold rounded-full hover:bg-orange-400 transition-all duration-300"
    >
      Ver proyectos
    </a>
  </div>
</section>
