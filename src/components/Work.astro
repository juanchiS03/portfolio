---
const { date, title, description } = Astro.props;
---

<li class="mb-12 ms-6">
    <span
        class="absolute flex items-center w-4 h-4 bg-[#fe9a0b] rounded-full -inset-s-2 ring-8 ring-slate-950"
    >
        <span class="w-2 h-2 bg-white rounded-full"></span>
    </span>

    <time class="block mb-2 text-sm font-mono leading-none text-[#ff8904]"
        >{date}</time
    >
    <h3 class="flex items-center mb-1 text-2xl font-bold text-white font-serif">
        {title}
    </h3>
    <p class="mb-4 text-base font-normal text-slate-400 max-w-2xl">
        {description}
    </p>
</li>
