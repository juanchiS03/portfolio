---
import Github from "./icons/Github.astro";

const { title, description, tags, image, link } = Astro.props;
---

<div class="group relative flex flex-row bg-slate-900/50 border border-slate-800 rounded-3xl overflow-hidden backdrop-blur-md transition-all hover:border-purple-500/50 hover:shadow-[0_0_40px_rgba(168,85,247,0.15)]">
  
  <div class="relative h-48 overflow-hidden">
    <div class="absolute inset-0 bg-linear-to-t from-slate-950 to-transparent z-10"></div>
    <img 
      src={image} 
      alt={title} 
      class="w-full h-full object-cover"
    />
  </div>

  <div class="p-6 px-10 flex flex-col grow z-20">

    <h3 class="text-2xl font-bold text-white mb-2 font-serif group-hover:text-[#feaf12] transition-colors text-left">
      {title}
    </h3>

    <p class="text-slate-400 text-sm leading-relaxed grow text-left">
      {description}
    </p>

    <a 
      href={link} 
      target="_blank" 
      class="inline-flex items-center text-[#ff8904] font-semibold text-sm group/link"
    >
      Ver Proyecto 
      <svg class="w-4 h-4 transition-transform group-hover/link:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
      </svg>
    </a>
  </div>
</div>