---
import AstroIcon from "./icons/AstroIcon.astro";
import CSharpIcon from "./icons/CSharpIcon.astro";
import Github from "./icons/Github.astro";
import GithubIcon2 from "./icons/GithubIcon2.astro";
import JavaIcon from "./icons/JavaIcon.astro";
import JavaScriptIcon from "./icons/JavaScriptIcon.astro";
import MySQLIcon from "./icons/MySQLIcon.astro";
import PostmanIcon from "./icons/PostmanIcon.astro";
import SalesforceIcon from "./icons/SalesforceIcon.astro";
import TailwindIcon from "./icons/TailwindIcon.astro";
---

<div class="flex flex-wrap justify-center gap-6 max-w-3xl mx-auto my-6">
  
  <div class="group relative flex flex-col items-center gap-2">
    <div class="flex items-center justify-center w-14 h-14 rounded-2xl bg-orange-500/10 border border-orange-500/20 backdrop-blur-md transition-all group-hover:scale-110 group-hover:border-orange-500/50 shadow-[0_0_20px_rgba(249,115,22,0.1)]">
         <JavaIcon />
    </div>
    <span class="mt-2 text-slate-400 text-[10px] font-mono opacity-0 group-hover:opacity-100 transition-opacity">Spring Boot</span>
    <div class="flex items-center justify-center w-14 h-14 rounded-2xl bg-orange-500/10 border border-orange-500/20 backdrop-blur-md transition-all group-hover:scale-110 group-hover:border-orange-500/50 shadow-[0_0_20px_rgba(249,115,22,0.1)]">
         <JavaScriptIcon />
    </div>
    <span class="mt-2 text-slate-400 text-[10px] font-mono opacity-0 group-hover:opacity-100 transition-opacity">JavaScript</span>
    <div class="flex items-center justify-center w-14 h-14 rounded-2xl bg-orange-500/10 border border-orange-500/20 backdrop-blur-md transition-all group-hover:scale-110 group-hover:border-orange-500/50 shadow-[0_0_20px_rgba(249,115,22,0.1)]">
         <CSharpIcon />
    </div>
    <span class="mt-2 text-slate-400 text-[10px] font-mono opacity-0 group-hover:opacity-100 transition-opacity">C#</span>
  </div>

  <div class="group relative flex flex-col items-center gap-2">
    <div class="flex items-center justify-center w-14 h-14 rounded-2xl bg-sky-500/10 border border-sky-500/20 backdrop-blur-md transition-all group-hover:scale-110 group-hover:border-sky-500/50 shadow-[0_0_20px_rgba(14,165,233,0.1)]">
       <SalesforceIcon />
    </div>
    <span class="mt-2 text-slate-400 text-[10px] font-mono opacity-0 group-hover:opacity-100 transition-opacity">Salesforce</span>
    <div class="flex items-center justify-center w-14 h-14 rounded-2xl bg-sky-500/10 border border-sky-500/20 backdrop-blur-md transition-all group-hover:scale-110 group-hover:border-sky-500/50 shadow-[0_0_20px_rgba(14,165,233,0.1)]">
       <GithubIcon2 />
    </div>
    <span class="mt-2 text-slate-400 text-[10px] font-mono opacity-0 group-hover:opacity-100 transition-opacity">Github</span>
  </div>

  <div class="group relative flex flex-col items-center gap-2">
    <div class="flex items-center justify-center w-14 h-14 rounded-2xl bg-pink-500/10 border border-pink-500/20 backdrop-blur-md transition-all group-hover:scale-110 group-hover:border-pink-500/50 shadow-[0_0_20px_rgba(236,72,153,0.1)]">
       <AstroIcon />
    </div>
    <span class="mt-2 text-slate-400 text-[10px] font-mono opacity-0 group-hover:opacity-100 transition-opacity">Astro</span>
    <div class="flex items-center justify-center w-14 h-14 rounded-2xl bg-pink-500/10 border border-pink-500/20 backdrop-blur-md transition-all group-hover:scale-110 group-hover:border-pink-500/50 shadow-[0_0_20px_rgba(236,72,153,0.1)]">
       <TailwindIcon />
    </div>
    <span class="mt-2 text-slate-400 text-[10px] font-mono opacity-0 group-hover:opacity-100 transition-opacity">Tailwind CSS</span>
  </div>

  <div class="group relative flex flex-col items-center gap-2">
    <div class="flex items-center justify-center w-14 h-14 rounded-2xl bg-emerald-500/10 border border-emerald-500/20 backdrop-blur-md transition-all group-hover:scale-110 group-hover:border-emerald-500/50 shadow-[0_0_20px_rgba(16,185,129,0.1)]">
       <MySQLIcon />
    </div>
    <span class="mt-2 text-slate-400 text-[10px] font-mono opacity-0 group-hover:opacity-100 transition-opacity">MySQL</span>
    <div class="flex items-center justify-center w-14 h-14 rounded-2xl bg-emerald-500/10 border border-emerald-500/20 backdrop-blur-md transition-all group-hover:scale-110 group-hover:border-emerald-500/50 shadow-[0_0_20px_rgba(16,185,129,0.1)]">
       <PostmanIcon />
    </div>
    <span class="mt-2 text-slate-400 text-[10px] font-mono opacity-0 group-hover:opacity-100 transition-opacity">Postman</span>
  </div>

</div>